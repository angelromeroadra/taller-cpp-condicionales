#include <iostream>

int main() {

    int año;
    std::cout << "Ingrese un año: ";
    std::cin >> año;

    bool divisible4   = (año % 4 == 0);
    bool divisible100 = (año % 100 == 0);
    bool divisible400 = (año % 400 == 0);

    std::cout << "Divisible entre 4? " << divisible4 << "\n";
    std::cout << "Divisible entre 100? " << divisible100 << "\n";
    std::cout << "Divisible entre 400? " << divisible400 << "\n\n";

    // Regla del calendario gregoriano
    bool esBisiesto = (divisible4 && !divisible100) || divisible400;

    std::cout << "Expresion evaluada:\n";
    std::cout << "(divisible4 && !divisible100) || divisible400\n\n";

    if (esBisiesto)
        std::cout << "Resultado: El año ES bisiesto.\n";
    else
        std::cout << "Resultado: El año NO es bisiesto.\n";

    return 0;
}
