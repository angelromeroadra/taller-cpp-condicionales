#include <iostream>

int main() {

    double peso, altura, imc;

    std::cout << "Ingrese su peso en kg: ";
    std::cin >> peso;

    std::cout << "Ingrese su altura en metros: ";
    std::cin >> altura;

    if (altura <= 0) {
        std::cout << "Altura invalida.\n";
        return 0;
    }

    imc = peso / (altura * altura);

    std::cout << "\nSu IMC es: " << imc << "\n\n";

    if (imc < 18.5) {
        std::cout << "Clasificacion: Bajo peso\n";
        std::cout << "Sugerencia: Mejorar la alimentacion y consultar un especialista.\n";
    }
    else if (imc >= 18.5 && imc < 25) {
        std::cout << "Clasificacion: Normal\n";
        std::cout << "Sugerencia: Mantener habitos saludables.\n";
    }
    else if (imc >= 25 && imc < 30) {
        std::cout << "Clasificacion: Sobrepeso\n";
        std::cout << "Sugerencia: Aumentar actividad fisica y cuidar la dieta.\n";
    }
    else if (imc >= 30 && imc < 35) {
        std::cout << "Clasificacion: Obesidad I\n";
        std::cout << "Sugerencia: Consultar a un profesional de salud.\n";
    }
    else {
        std::cout << "Clasificacion: Obesidad II\n";
        std::cout << "Sugerencia: Atencion medica recomendada.\n";
    }

    return 0;
}
